{
  "compilerOptions": {
    "target": "ES2018",
    "jsx": "react-jsx",
    "module": "commonjs",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2019"],
    "types": ["node"]
  },
  "include": ["src/**/*"]
}